# Alpha-Paca Crypto — Environment Variables
# Copy to ../.env.local and fill in real values
# (The crypto service reads from the parent directory's .env.local)

# ── Alpaca Broker ────────────────────────────
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
ALPACA_PAPER=true

# ── External API Keys ───────────────────────
SERPER_API_KEY=your_serper_key
TAVILY_API_KEY=your_tavily_key
ANTHROPIC_API_KEY=your_anthropic_key

# ── Database / Cache ────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@host:port/dbname
REDIS_URL=redis://default:pass@host:port

# ── Telegram ─────────────────────────────────
TELEGRAM_BOT_TOKEN=from_botfather
TELEGRAM_CHAT_ID=your_chat_or_group_id

# ── Crypto Trading ───────────────────────────
CRYPTO_MAX_CAPITAL=0
CRYPTO_PAIRS=BTC/USD,ETH/USD,SOL/USD,DOGE/USD,LINK/USD
CRYPTO_RISK_PER_TRADE_PCT=2.0
CRYPTO_MAX_POSITION_PCT=30
CRYPTO_MAX_DRAWDOWN_PCT=10
CRYPTO_MAX_TOTAL_EXPOSURE_PCT=90
CRYPTO_MIN_TRADE_INTERVAL_SEC=300
CRYPTO_CONFIDENCE_THRESHOLD=0.7
